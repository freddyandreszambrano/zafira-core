# ZAFIRA-CORE local environment


# App
DEBUG=True
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0


# Database
# PSQL=0 usa SQLite local en db.sqlite3.
# PSQL=1 usa PostgreSQL con las variables DB_*.
PSQL=0

# PostgreSQL only
DB_NAME=zafira
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_SCHEMA=public


# Browser / frontend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000
FRONTEND_URL=http://localhost:3000


# Optional SMTP email
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@zafira.com


# Optional tokens/security
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
# JWT_ALGORITHM=HS256
# PASSWORD_RESET_TIMEOUT=24
# SECURE_SSL_REDIRECT=False
# SESSION_COOKIE_SECURE=False
# CSRF_COOKIE_SECURE=False
