# ZAFIRA-CORE local environment


# App
DEBUG=True
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
# Para probar desde mobile en la misma red, agrega la IP LAN actual:
# ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,192.168.0.3
# Si la IP cambia seguido, usa solo en desarrollo:
# ALLOWED_HOSTS=*


# Database
# PSQL=0 usa SQLite local en db.sqlite3.
# PSQL=1 usa PostgreSQL con las variables DB_*.
PSQL=0

# PostgreSQL only
DB_NAME=zafira
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_SCHEMA=public


# Browser / frontend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000
FRONTEND_URL=http://localhost:3000


# Celery / Redis
# Broker y backend de resultados para tareas asíncronas.
# Local: usa el Redis de "make redis-local". En Docker: redis://redis:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Ejecuta las tareas en el momento, sin broker (útil para tests/depuración).
CELERY_TASK_ALWAYS_EAGER=False


# Email (Resend vía django-anymail)
# Remitente: debe pertenecer a un dominio verificado en Resend.
# Para pruebas usa el remitente de Resend (solo envía a tu propio correo de cuenta):
#   DEFAULT_FROM_EMAIL=onboarding@resend.dev
# En producción usa tu dominio verificado, ej: "Zafira <no-reply@tudominio.com>"
# Email SMTP Gmail
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

# Reemplazar por sus propios datos
EMAIL_HOST_USER=freddyandres0614@gmail.com
EMAIL_HOST_PASSWORD=elnr vftd iusz xmfo


# Email (Resend vía django-anymail)
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=tu_correo@gmail.com


# Groq (selección de candidatos por texto)
GROQ_API_KEY=
# Google Gemini Flash (evaluación visual de outfits)
GEMINI_API_KEY=

