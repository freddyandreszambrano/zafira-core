# ZAFIRA-CORE — entorno local

# App
DEBUG=True
SECRET_KEY=change-me
# Mobile en la misma red: agrega tu IP LAN (o usa * solo en dev).
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database — PSQL=0 SQLite · PSQL=1 PostgreSQL (variables DB_*)
PSQL=0
DB_NAME=zafira
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_SCHEMA=public

# Frontend / CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000
FRONTEND_URL=http://localhost:3000

# Celery / Redis (EAGER=True ejecuta sin broker, para tests)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=False

# Email — proveedor: gmail (default) | resend
EMAIL_PROVIDER=gmail
# Gmail SMTP (la contraseña es un App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu_correo@gmail.com
EMAIL_HOST_PASSWORD=app_password_de_gmail
# Resend

RESEND_API_KEY=
# Remitente: Gmail vacío cae a EMAIL_HOST_USER; Resend usa dominio verificado.
DEFAULT_FROM_EMAIL=
