# Normaliza EOL — clave para WSL + editores Windows
* text=auto eol=lf

# Texto explícito
*.py    text eol=lf
*.html  text eol=lf
*.js    text eol=lf
*.css   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf

# Scripts shell — siempre LF
*.sh    text eol=lf

# Binarios
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   text eol=lf
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.sqlite3 binary
db.sqlite3 binary
